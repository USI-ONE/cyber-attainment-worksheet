# Copy this file to .env.local and fill in the values from 1Password.
# Never commit .env.local.

# ============================================================
# Supabase
# ============================================================
# Project URL — visible at supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://pfhlhwawiyzwwhwbcmsz.supabase.co

# Publishable key (formerly "anon" key) — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (formerly "service_role" key) — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_...

# ============================================================
# Tenant pin
# ============================================================
# Each Vercel project is pinned to one tenant via this var. Locally, pick the tenant you're working on.
# Must match a row in public.tenants.slug.
TENANT_SLUG=collision-leaders

# Optional: override the hostname-based tenant resolution (useful in local dev when there's no real hostname).
# Defaults to TENANT_SLUG if unset.
# NEXT_PUBLIC_TENANT_SLUG=collision-leaders

# ============================================================
# Authentication enforcement
# ============================================================
# When 'true', every page (other than /auth/*) requires a session cookie.
# When unset / 'false', anonymous browsing is allowed (rollout-mode legacy).
# Flip to 'true' once every tenant deploy has a real user list.
# AUTH_REQUIRED=true

# ============================================================
# Operator deploy
# ============================================================
# Set on the Portfolio Hub Vercel project ONLY. Flips the deploy into
# operator mode — no tenant chrome, /hub becomes the landing page,
# /admin/* (platform-wide user + tenant administration) is exposed.
# Leave UNSET on every customer tenant deploy.
# OPERATOR_MODE=true

# ============================================================
# Email (Resend) — transactional mail for invites + password resets
# ============================================================
# Without these, invites and password resets are silently logged to the
# server console and the admin copy/pastes the URL manually. Set them to
# turn on real outbound email.
#
# 1. Sign up at https://resend.com and verify the sending domain
#    (DKIM + SPF + DMARC records in DNS for usicomputer.com, or
#    whichever domain you want to send from).
# 2. Generate an API key under resend.com/api-keys.
# 3. Add the variables here (or on Vercel for each deploy).
#
# RESEND_API_KEY=re_live_...
# EMAIL_FROM=TrustOS <noreply@usicomputer.com>
# EMAIL_REPLY_TO=support@usicomputer.com           # optional
# EMAIL_BCC=audit-archive@usicomputer.com          # optional, comma-separated

# ============================================================
# Local dev
# ============================================================
# Where the app is hosted. Used for OAuth redirect callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
